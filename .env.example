# ====================================================================
# AI Agent Platform — пример конфигурации.
# Скопируй в .env:  cp .env.example .env  и заполни GROQ_API_KEY.
# ====================================================================

# --- PostgreSQL ---
POSTGRES_USER=aiap
POSTGRES_PASSWORD=aiap_password
POSTGRES_DB=aiap
# Хостовый порт. Если локально уже занят 5432 — поменяй (контейнеры внутри всё равно используют 5432).
POSTGRES_PORT=5433

# --- Backend (NestJS) ---
BACKEND_PORT=4000
# Секрет для подписи JWT. В проде замени на длинную случайную строку.
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Groq (LLM + function-calling) ---
# BYOK: каждый пользователь вводит свой ключ в UI («Настройки») — он хранится
# в браузере и шлётся в заголовке x-groq-key. Этот серверный ключ НЕОБЯЗАТЕЛЕН
# и работает лишь как фоллбэк, если пользователь свой не задал. Можно оставить пустым.
GROQ_API_KEY=
# Модель с поддержкой tool-calling. См. https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Ограничение CORS-источников (через запятую), напр. https://your-app.vercel.app
# Пусто = разрешить любой origin (удобно локально, не для прода).
CORS_ORIGIN=

# --- Эмбеддинги ---
# Считаются ЛОКАЛЬНО через @xenova/transformers (модель all-MiniLM-L6-v2, 384 dim).
# Ключ не нужен. Модель (~90 МБ) скачивается один раз при первом запуске.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Frontend (Next.js) ---
# URL backend, доступный из браузера пользователя.
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_PORT=3000
