# ====================================================================
# AI Agent Platform — example configuration.
# Copy to .env:  cp .env.example .env  and fill in GROQ_API_KEY.
# ====================================================================

# --- PostgreSQL ---
POSTGRES_USER=aiap
POSTGRES_PASSWORD=aiap_password
POSTGRES_DB=aiap
# Host port. Change it if 5432 is already taken locally (containers still use 5432 internally).
POSTGRES_PORT=5433

# --- Backend (NestJS) ---
BACKEND_PORT=4000
# Secret used to sign JWTs. In production replace it with a long random string.
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_IN=7d

# --- Groq (LLM + function-calling) ---
# BYOK: every user enters their own key in the UI ("Settings") — it is stored
# in the browser and sent in the x-groq-key header. This server-side key is OPTIONAL
# and acts only as a fallback when the user has not set their own. It may be left empty.
GROQ_API_KEY=
# A model with tool-calling support. See https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# Allowed CORS origins (comma-separated), e.g. https://your-app.vercel.app
# Empty = allow any origin (handy locally, not for production).
CORS_ORIGIN=

# --- Embeddings ---
# Computed LOCALLY via @xenova/transformers (all-MiniLM-L6-v2 model, 384 dim).
# No key required. The model (~90 MB) is downloaded once on first run.
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIM=384

# --- Frontend (Next.js) ---
# Backend URL as reachable from the user's browser.
NEXT_PUBLIC_API_URL=http://localhost:4000
FRONTEND_PORT=3000
